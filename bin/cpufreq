#!/bin/bash

if [ $# -gt 1 ]
then
    echo "usage: cpufreq [interval ms]"
    exit
fi

if [ -n "$1" ]
then
    interval_ms=$1
else
    interval_ms=1000
fi
interval=$(echo $interval_ms 1000 | awk '{printf "%.1f", $1/$2}')

adb root 1> /dev/null
adb wait-for-device

cpu_num=$(adb shell cat /proc/cpuinfo | grep -c "processor")
echo "cpu: $cpu_num"
cpuinfo_max_freq=$(adb shell cat /sys/devices/system/cpu/cpu0/cpufreq/cpuinfo_max_freq)
echo "cpuinfo_max_freq: $cpuinfo_max_freq"
scaling_governor=$(adb shell cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor)
echo "scaling_governor: $scaling_governor"
scaling_max_freq=$(adb shell cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_max_freq)
#echo "scaling_max_freq: $scaling_max_freq"
echo
echo interval=$interval_ms"ms"
#echo interval=$interval"s"
echo

#for((i=0; i<$cpu_num; i++)); do
#    scaling_governor=$(adb shell cat /sys/devices/system/cpu/cpu$i/cpufreq/scaling_governor 2>/dev/null | tr -d '\r\n') 
#    scaling_max_freq=$(adb shell cat /sys/devices/system/cpu/cpu$i/cpufreq/scaling_max_freq 2>/dev/null)
#    echo "cpu[$i]: ${scaling_governor} ${scaling_max_freq}"
#done
#echo

echo -e "max     cpu0    cpu1    cpu2    cpu3"
echo -e "------- ------- ------- ------- -------"

while true; do 
    eval $(adb shell \
        'echo \
			$(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_max_freq) \
			$(cat /sys/devices/system/cpu/cpu0/cpufreq/cpuinfo_max_freq) \
            $(cat /sys/devices/system/cpu/cpu0/cpufreq/cpuinfo_cur_freq 2>/dev/null || echo 0) \
            $(cat /sys/devices/system/cpu/cpu1/cpufreq/cpuinfo_cur_freq 2>/dev/null || echo 0) \
            $(cat /sys/devices/system/cpu/cpu2/cpufreq/cpuinfo_cur_freq 2>/dev/null || echo 0) \
            $(cat /sys/devices/system/cpu/cpu3/cpufreq/cpuinfo_cur_freq 2>/dev/null || echo 0)' | \
			awk '{ print "scaling_max_freq="$1,";cpuinfo_max_freq="$2,";cpu0="$3,";cpu1="$4,";cpu2="$5,";cpu3="$6}')
	 if [ $scaling_max_freq == $cpuinfo_max_freq ]
		 then
			 echo -ne "\e[39m"
		 else \
			 echo -ne "\e[91m"
	 fi
	printf '%7d %7d %7d %7d %7d\n' "$scaling_max_freq" "$cpu0" "$cpu1" "$cpu2" "$(echo $cpu3 | tr -d '\r')"
	
    sleep $interval
done
